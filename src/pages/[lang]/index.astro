---
import Layout from "@/layouts/Layout.astro";
import CharacterProfile from "@/components/CharacterProfile.astro";
import CharacterSheet from "@/components/CharacterSheet.astro";
import CharacterHistory from "@/components/CharacterHistory.astro";
import CharacterInventory from "@/components/CharacterInventory.astro";
import SendARaven from "@/components/SendARaven.astro";
import { getEntry } from "astro:content";
import { locales, localizePath } from "@/utils/locale.ts";

export const prerender = true;
export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang }}));
}

const seo = await getEntry("seo", localizePath(Astro, "seo"))!;
---

<Layout title={seo.data.title} description={seo.data.description}>
  <CharacterProfile />
  <CharacterSheet />
  <CharacterHistory />
  <CharacterInventory />
  <SendARaven />
</Layout>
